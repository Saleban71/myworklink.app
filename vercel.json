{
  "version": 2,
  "buildCommand": "echo 'Static HTML deployment - no build needed'",
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/:path((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
